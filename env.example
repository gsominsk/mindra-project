# ============================================================
# mindra-website environment template
# Copy to .env on the server and fill in real values.
# All .env* files are gitignored — never commit real secrets.
# ============================================================

# --- SMTP (contact form) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
RECIPIENT_EMAIL=where-to-send@example.com

# --- Auth (plaintext credentials) ---
# ⚠️ PRODUCTION: replace `admin`/`admin` with strong unique passwords.
ADMIN_PASSWORD=change-me-to-a-strong-password
PARTY_PROMPTS_USER=admin
PARTY_PROMPTS_PASS=change-me-to-a-strong-password

# --- SQLite database path ---
# In Docker: the sqlite-data volume mounts at /app/prisma, so the DB file
# lives at /app/prisma/dev.db and persists across container restarts.
# Locally (npm run dev): use file:./dev.db (relative to the project root).
# Note: docker-compose.yml overrides this via the `environment:` block, so
# the value here only matters for local dev and as documentation.
DATABASE_URL=file:/app/prisma/dev.db

# --- Media URL (served by the reverse proxy / volume mount) ---
# In Docker: set to /media (handled in docker-compose.yml `environment`).
NEXT_PUBLIC_MEDIA_URL=/media

# --- Instagram sync (ig-sync service profile) ---
IG_TARGET_PROFILE=your.ig.profile

# --- LLM provider keys ---
# ⚠️ PRODUCTION: rotate the OpenRouter key before deploy if it was used
# during development (see memory-bank 19.5).
# OpenRouter key is ALSO stored in the PromptSettings table in SQLite;
# this env var is only used by the Instagram sync pipeline.
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key
NVIDIA_API_KEY=your-nvidia-key
LLM_PROVIDER=openrouter


